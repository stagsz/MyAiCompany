{
    "version": 2,
    "regions": ["fra1"],
    "buildCommand": "npm run build",
    "functions": {
          "api/index.js": {
                  "memory": 1024,
                  "maxDuration": 60
          }
    },
    "routes": [
          {
                  "src": "/(.*)",
                  "dest": "/api/index.js"
          }
    ]
}
